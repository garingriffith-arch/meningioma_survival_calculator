class(obj)
# R/02_train_model_pvalue.R  (ROBUST TERM SELECTION; no invalid formulas)
suppressPackageStartupMessages({
library(dplyr)
library(rsample)
library(survival)
library(forcats)
library(readr)
})
INPUT_PATH <- "data/processed/analysis_df.rds"
SEED <- 2026
TRAIN_PROP <- 0.70
P_CUTOFF <- 0.20   # PI-style liberal threshold
df <- readRDS(INPUT_PATH)
terms_all <- c(
"AGE",
"SEX",
"RACE",
"SPANISH_HISPANIC_ORIGIN",
"INSURANCE_STATUS",
"MED_INC_QUAR_16",
"NO_HSD_QUAR_16",
"UR_CD_13",
"CDCC_TOTAL_BEST",
"GRADE",
"HISTOLOGY",
"BEHAVIOR",
"TUMOR_SIZE_FINAL",
"METS_AT_DX_BRAIN",
"METS_AT_DX_BONE",
"METS_AT_DX_LIVER",
"METS_AT_DX_LUNG",
"METS_AT_DX_DISTANT_LN",
"METS_AT_DX_OTHER"
)
# ---- Prep analysis frame ----
analysis_df <- df %>%
select(time_months, event, all_of(terms_all)) %>%
mutate(
time_months = ifelse(time_months <= 0, 0.01, time_months),
# IMPORTANT: treat coded categoricals as factors (so RACE becomes dummy columns)
across(all_of(setdiff(terms_all, c("AGE","TUMOR_SIZE_FINAL"))), ~ fct_explicit_na(as.factor(.x), "Unknown")),
AGE = ifelse(is.na(AGE), median(AGE, na.rm = TRUE), AGE),
TUMOR_SIZE_FINAL = ifelse(is.na(TUMOR_SIZE_FINAL), median(TUMOR_SIZE_FINAL, na.rm = TRUE), TUMOR_SIZE_FINAL)
)
# ---- Train/test split ----
set.seed(SEED)
split <- initial_split(analysis_df, prop = TRAIN_PROP, strata = event)
train_df <- training(split)
test_df  <- testing(split)
# ---- Full Cox model ----
full_form <- reformulate(termlabels = terms_all, response = "Surv(time_months, event)")
full_fit <- coxph(full_form, data = train_df, x = TRUE)
# ---- Global p-values per TERM (correct for factors) ----
a <- anova(full_fit, test = "Chisq")
term_p <- data.frame(
term = rownames(a),
p = a[, "Pr(>|Chi|)"],
row.names = NULL
)
# Remove residuals row if present + drop NA p-values safely
term_p <- term_p %>%
filter(term != "Residuals") %>%
filter(!is.na(p))
# Terms that pass cutoff
keep_terms <- term_p$term[term_p$p <= P_CUTOFF]
keep_terms <- keep_terms[!is.na(keep_terms) & nzchar(keep_terms)]
cat("\n--- Term p-values from full model ---\n")
print(term_p)
cat("\nTerms retained after p-value filter (p <=", P_CUTOFF, "):\n")
print(keep_terms)
# ---- Build reduced model formula safely ----
# If nothing passes cutoff, fit intercept-only model (still valid)
if (length(keep_terms) == 0) {
cat("\nNo terms met p-value cutoff. Fitting intercept-only Cox model.\n")
reduced_form <- as.formula("Surv(time_months, event) ~ 1")
} else {
reduced_form <- reformulate(termlabels = keep_terms, response = "Surv(time_months, event)")
}
reduced_fit <- coxph(reduced_form, data = train_df, x = TRUE)
# ---- Test-set evaluation ----
lp_test <- as.numeric(predict(reduced_fit, newdata = test_df, type = "lp"))
c_test <- survival::concordance(
Surv(time_months, event) ~ I(-lp_test),
data = test_df
)$concordance
cat("\nFINAL Test C-index (p-value–selected Cox):", round(c_test, 3), "\n")
saveRDS(
list(
full_fit = full_fit,
reduced_fit = reduced_fit,
term_pvalues = term_p,
kept_terms = keep_terms,
test_cindex = c_test
),
"model/cox_model_pvalue.rds"
)
