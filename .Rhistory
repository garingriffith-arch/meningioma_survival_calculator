source("R/03_evaluate_model.R")
source("R/03_evaluate_model.R")
source("R/02_train_model.R")
source("R/03_evaluate_model.R")
# R/export_for_pycox.R
df <- readRDS("data/processed/analysis_df.rds")
# Ensure strictly positive time for pycox (and many survival NN libs)
df$time_months <- ifelse(df$time_months <= 0, 0.01, df$time_months)
# Keep only curated baseline predictors + outcomes
keep <- c(
"time_months","event",
"AGE","SEX","RACE","SPANISH_HISPANIC_ORIGIN","INSURANCE_STATUS",
"MED_INC_QUAR_16","NO_HSD_QUAR_16","UR_CD_13",
"CDCC_TOTAL_BEST",
"GRADE","HISTOLOGY","BEHAVIOR","TUMOR_SIZE_FINAL",
"METS_AT_DX_BRAIN","METS_AT_DX_BONE","METS_AT_DX_LIVER","METS_AT_DX_LUNG",
"METS_AT_DX_DISTANT_LN","METS_AT_DX_OTHER"
)
out <- df[, keep]
dir.create("data/processed", showWarnings = FALSE, recursive = TRUE)
write.csv(out, "data/processed/meningioma_nn_input.csv", row.names = FALSE)
cat("Wrote data/processed/meningioma_nn_input.csv with", nrow(out), "rows\n")
